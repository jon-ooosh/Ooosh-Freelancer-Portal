{
  "name": "@ooosh/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Ooosh Operations Platform — Backend API",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/services/fonts && cp src/services/fonts/*.ttf dist/services/fonts/",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest --passWithNoTests",
    "db:migrate": "tsx src/migrations/run.ts up",
    "db:migrate:down": "tsx src/migrations/run.ts down",
    "db:seed": "tsx src/seeds/run.ts",
    "db:backup": "tsx src/scripts/backup.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "libphonenumber-js": "^1.13.8",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "socket.io": "^4.8.0",
    "stripe": "^22.3.0",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
