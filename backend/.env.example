# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://ooosh:ooosh_dev@localhost:5432/ooosh_operations

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# PII Encryption (AES-256-GCM, services/encryption.ts)
# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
# CRITICAL: never change this once data has been encrypted with it — encrypted
# fields become permanently unrecoverable. Without it, bank-detail storage and
# any other encrypted PII is refused (degrades cleanly, no plaintext fallback).
ENCRYPTION_KEY=

# HireHop API
HIREHOP_DOMAIN=myhirehop.com
HIREHOP_API_TOKEN=
HIREHOP_EXPORT_KEY=          # From HireHop Settings → Company Settings → Export Key (webhook verification)
# Staging Calculator stock fetch (modules/stock/export_data.php) — the bulk stock
# export ID + key pair (the values in the working export URL:
# export_data.php?id=<HIREHOP_EXPORT_ID>&key=<HIREHOP_STOCK_EXPORT_KEY>&depot=1&cat=444).
# The stock-export KEY is usually DIFFERENT from the webhook HIREHOP_EXPORT_KEY above,
# so set it separately here (the service falls back to HIREHOP_EXPORT_KEY only if unset).
HIREHOP_EXPORT_ID=           # HireHop stock-export ID (e.g. 2346)
HIREHOP_STOCK_EXPORT_KEY=    # HireHop stock-export KEY (from the working export URL)

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ooosh-operations

# Email Service (SMTP via Google Workspace)
EMAIL_MODE=test
EMAIL_TEST_REDIRECT=jon@oooshtours.co.uk
# Per-template allowlist used while EMAIL_MODE=test. Templates listed here go
# to their real recipient (no banner, no [TEST] subject, CCs honoured) without
# flipping the whole system live. Comma-separated template IDs. Ignored when
# EMAIL_MODE=live (every template goes live then). sendRaw() is NOT covered.
EMAIL_LIVE_TEMPLATES=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@oooshtours.co.uk
SMTP_PASS=
SMTP_FROM=Ooosh Tours <notifications@oooshtours.co.uk>

# Vehicle Module (Netlify proxy — short-term until migrated to Express)
VEHICLE_MODULE_URL=https://ooosh-vehicles.netlify.app

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
