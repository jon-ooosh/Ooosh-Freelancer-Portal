# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://ooosh:ooosh_dev@localhost:5432/ooosh_operations

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# HireHop API
HIREHOP_DOMAIN=myhirehop.com
HIREHOP_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ooosh-operations

# Google Workspace (Email)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Vehicle Module (Netlify proxy — short-term until migrated to Express)
VEHICLE_MODULE_URL=https://ooosh-vehicles.netlify.app

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
